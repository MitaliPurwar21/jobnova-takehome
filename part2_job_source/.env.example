# Copy this file to .env and fill in values. None of these are strictly
# required — the agent runs with no keys at all (heuristics + keyless lookups).

# Groq API key — used by the web agent to choose which links to follow.
# Without it the agent falls back to keyword heuristics. Free tier at
# https://console.groq.com/keys (same key as Part 1).
GROQ_API_KEY=your_groq_api_key

# Optional: a third-party LinkedIn crawler API endpoint that takes ?url=<job_url>
# and returns JSON with a "company_name" field. Leave blank to use LinkedIn's
# public guest endpoint (the default, no key needed).
LINKEDIN_API_URL=
