# Copy this file to .env.local and fill in your real values.
# Do NOT commit .env.local — it contains secrets.

# LiveKit Cloud (from your "jobnova" project)
# Find these in the LiveKit Cloud dashboard: Settings -> Keys.
LIVEKIT_URL=wss://your-project-subdomain.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Groq (powers STT + LLM + TTS), Free tier at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
